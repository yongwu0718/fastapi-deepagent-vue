# ============================================================
# index-rag Dockerfile (后端镜像)
# ------------------------------------------------------------
# 依据 docker-best-practices 工作流：
#   - 多阶段构建（builder → runtime）
#   - slim 基础镜像
#   - 缓存友好：先复制依赖清单再安装
#   - 非 root 用户运行
#   - WORKDIR / 显式端口 / exec 形式 CMD
# ============================================================

# ── 阶段 1：构建依赖（builder） ───────────────────────────────
FROM python:3.12-slim AS builder

# 避免 .pyc 与缓冲输出
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /build

# 导入 uv 二进制（并行下载，比 pip 快 10-100 倍）
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# 先复制依赖清单：仅当 pyproject.toml/uv.lock 变更时才会重建此层
COPY pyproject.toml uv.lock ./

# 创建最小包结构，仅安装依赖（利用缓存：源码变更不会使此层失效）
RUN mkdir -p backend && touch backend/__init__.py && \
    uv pip install --prefix=/install --system . && \
    rm -rf backend

# 复制源码并重新安装包（依赖已缓存，仅更新包元数据）
COPY backend ./backend
COPY model_config.yaml ./
RUN uv pip install --prefix=/install --system --no-deps .

# ── 阶段 2：运行时镜像（runtime） ────────────────────────────
FROM python:3.12-slim AS runtime

# 避免 .pyc 与缓冲输出
ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

# 运行时仅需最小化的系统库
RUN apt-get update && apt-get install -y --no-install-recommends \
        libgomp1 \
        ca-certificates \
        curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# 从 builder 阶段复制已安装的 Python 包
COPY --from=builder /install /usr/local

# 复制项目源码与配置文件
COPY backend ./backend
COPY pyproject.toml model_config.yaml ./

# 创建非 root 用户
RUN groupadd --system appgroup \
    && useradd --system --gid appgroup --home /app --shell /usr/sbin/nologin appuser \
    && chown -R appuser:appgroup /app

USER appuser

# 健康检查
HEALTHCHECK --interval=30s --timeout=10s --start-period=20s --retries=3 \
    CMD python -c "import backend; print('healthcheck ok')"

EXPOSE 8000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
