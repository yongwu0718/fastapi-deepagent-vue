{
    "math": {
        "transport": "stdio",
        "command": "{PYTHON_EXECUTABLE}",
        "args": ["{MCP_SERVER_DIR}\\local_mcp.py"]
    },
    "WebSearch": {
        "transport": "http",
        "url": "https://dashscope.aliyuncs.com/api/v1/mcps/WebSearch/mcp",
        "headers": {
            "Authorization": "Bearer {DASHSCOPE_API_KEY}"
        }
    },
    "lark-mcp": {
      "transport": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@larksuiteoapi/lark-mcp",
        "mcp",
        "-a",
        "{App_ID}",
        "-s",
        "{App_Secret}",
        "-t",
        "preset.calendar.default"
      ]
    }
}
