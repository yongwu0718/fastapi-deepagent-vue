# ============================================================
# Index RAG 环境变量配置
# ============================================================

# ──────────────────────────────────────────────────────────
# 1. Agent 相关路径
# ──────────────────────────────────────────────────────────
# model_config 相关路径
MODEL_CONFIG_DIR =model_config.yaml

# system_prompt 相关路径
SYSTEM_PROMPT_DIR =backend/core/prompts/system_prompt.txt

# mcp_server 相关路径
MCP_SERVER_DIR =backend/core/utils/mcp/mcp_server.json

# Agent 记忆规则文件目录
MEMORY_DIR = backend/memory_skill/memory

# Agent 技能文件目录
SKILLS_DIR = backend/memory_skill/skill

# 技能开关配置文件
SKILLS_CONFIG_PATH = backend/core/skill_manager/skills_config.yaml

# ──────────────────────────────────────────────────────────
# 2. 文档索引路径
# ──────────────────────────────────────────────────────────
# 知识库索引文档路由
DOC_INDEX = knowledge-base

# 工作空间目录
WORKSPACE_DIR = knowledge-base/workspace

# 上传文件目录
UPLOADS_DIR = knowledge-base/uploads

# ──────────────────────────────────────────────────────────
# 3. rag 相关路径
# ──────────────────────────────────────────────────────────
# RAG 原始文档目录
RAW_DOCS_DIR = backend/rag_pipeline/vectorstore/raw

# RAG 清洗后文档目录
CLEAN_DOCS_DIR = backend/rag_pipeline/vectorstore/cleaned

# 分块预览输出目录
PREVIEW_CHUNKS_DIR=backend/rag_pipeline/vectorstore/preview_chunks

# ──────────────────────────────────────────────────────────
# 4. 数据库路径
# ──────────────────────────────────────────────────────────
# SQLite 检查点数据库（对话记忆持久化）
CHECKPOINT_DB=data/save_db/memory/checkpoints.db

# SQLite 存储数据库（长期记忆存储）
STORE_DB=data/save_db/store/store.db

# Chroma 向量数据库（Deep Agent 知识库检索）
CHROMA_DB=data/save_db/chroma_db
COLLECTION_MEMORY_NAME=memory
COLLECTION_NAME=documents

# ──────────────────────────────────────────────────────────
# 5. 运行时输出目录
# ──────────────────────────────────────────────────────────
# 对话日志保存目录
CHAT_LOG_DIR=data/save_run_file/save_chat_history

# 状态快照保存目录
SAVE_STATE_DIR=data/save_run_file/save_state

# 摘要存储目录
SUMMARIZATION_DIR=data/save_run_file/summarization


# ──────────────────────────────────────────────────────────
# 6. CORS 跨域配置
# ──────────────────────────────────────────────────────────
# 允许的前端来源，多个用逗号分隔；留空使用默认值
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000


# ──────────────────────────────────────────────────────────
# 7. Langfuse 可观测性配置
# ──────────────────────────────────────────────────────────
LANGFUSE_TRACING_ENABLED=True
LANGFUSE_SECRET_KEY=your_secret_key_here
LANGFUSE_PUBLIC_KEY=your_public_key_here
LANGFUSE_BASE_URL=https://cloud.langfuse.com
